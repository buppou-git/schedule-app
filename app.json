{
  "expo": {
    "name": "UniCal",
    "slug": "multi-calendar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon2.png",
    "scheme": "com.buppou.multicalendar",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon2.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.buppou.multicalendar"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon2.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "@react-native-community/datetimepicker",
      "@react-native-google-signin/google-signin",
      "expo-secure-store",
      [
        "expo-calendar",
        {
          "calendarPermission": "予定を標準カレンダーと同期するためにアクセスします。"
        }
      ],
      "react-native-google-mobile-ads",
      "expo-tracking-transparency"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "c5501d38-da79-4ec9-a57f-c84c899d155d"
      }
    },

    "plugins": [
      [
        "react-native-google-mobile-ads",
        {
          "adMobAppId": "ca-app-pub-3940256099942544~1458002511", // テスト用ID
          "userTrackingUsageDescription": "あなたの好みに合わせた広告を表示するために使用します。"
        }
      ]
    ]
  }
}
